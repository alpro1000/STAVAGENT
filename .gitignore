node_modules/
package-lock.json
*.db

# Claude Code project state — track shared config (settings/skills),
# ignore personal overrides (.claude/settings.local.json stays ignored via .claude/*)
.claude/*
!.claude/skills/
!.claude/settings.json
!.claude/agents/

# URS cache — derived locally by scripts/urs_cache/, ~140 MB
data/urs_cache.db
data/urs_cache.db-journal
data/urs_cache.db-wal
data/urs_cache.db-shm
data/urs_cache/
urs_cache_*.zip

# Environment files (keep .env.example tracked)
.env
.env.*
!.env.example

# Build output
dist/
build/
.next/
.vercel/
.turbo/

# Logs
*.log
logs/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Python
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.venv/
venv/

# Coverage
coverage/
.coverage
htmlcov/

# Local-only outputs (regenerated from extract_all_pdfs.py)
extracted_data/

# Generated DXF (Phase 0.5 — produced from inputs/dwg/ by dwg2dxf, ~300 MB total,
# regeneratable in <10s via convert_batch; some files exceed GitHub's 100 MB cap)
test-data/libuse/inputs/dxf/*.dxf

# Generated DXF (any STAVAGENT project — gitignored, regeneratable
# via scripts/infrastructure/dwg_to_dxf_batch.py)
test-data/*/inputs/dxf/*.dxf
test-data/*/sources/*/dxf/*.dxf

# libredwg in-tree clone (build script clones to /tmp by default)
/libredwg/

# Π.0a DXF parse cache (perf optimization, regeneratable from sources/*/dxf/)
/.pi_0_cache/

# DXF-First validation artifacts (regenerated by dxf_vymery_export.py each
# pipeline run — non-deliverable cross-check; previously churned & blocked
# branch checkout). Sources stay tracked; these are pure projections.
test-data/*/outputs/DXF_VYMERY*.json
test-data/*/outputs/DXF_VYMERY_crosscheck*.md

# RD Jáchymov regenerated deliverables (build artifacts — single-source
# projection from items.json via tools/regenerate_all_views.py). The binary
# xlsx/docx churn on every run (zip timestamps) and previously blocked branch
# checkout. The delivered package is preserved (tracked) in
# snapshots/delivered_RD_Jachymov/. Regenerate on demand.
test-data/RD_Jachymov_dum/outputs/ATOMIC_FLAT.xlsx
test-data/RD_Jachymov_dum/outputs/VYMERY_SOUHRN.xlsx
test-data/RD_Jachymov_dum/outputs/Otazky_pro_Karla_a_projektanty.docx
test-data/RD_Jachymov_dum/outputs/Vykaz_vymer_RD_Jachymov_ATOMIC_WORKLIST.xlsx
test-data/RD_Jachymov_dum/outputs/Vykaz_vymer_RD_Jachymov_VSE_VARIANTY.xlsx
test-data/RD_Jachymov_dum/outputs/Vykaz_vymer_RD_Jachymov_VSE_VARIANTY_v2.xlsx
test-data/RD_Jachymov_dum/outputs/Vykaz_vymer_RD_Jachymov_VSE_VARIANTY_v2_final.xlsx
test-data/RD_Jachymov_dum/outputs/Vykaz_vymer_RD_Jachymov_KROS_format_v3_final.xlsx

# RD Jáchymov regenerated audit/log projections (deterministic build artifacts
# from items.json; churn on re-run). Source items.json + FROZEN baseline + the
# delivered snapshot stay tracked.
test-data/RD_Jachymov_dum/outputs/items_completeness_audit_v2.json
test-data/RD_Jachymov_dum/outputs/items_completeness_report_v2.md
test-data/RD_Jachymov_dum/outputs/items_quality_audit.json
test-data/RD_Jachymov_dum/outputs/items_quality_report.md
test-data/RD_Jachymov_dum/outputs/atomic_decomposition_map.json
test-data/RD_Jachymov_dum/outputs/_phase4_excel_extend_log.json
test-data/RD_Jachymov_dum/outputs/_phase4_finalize_log.json
test-data/RD_Jachymov_dum/outputs/phase6_file_b_validation_log.json
