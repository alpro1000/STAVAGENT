{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__github__pull_request_read",
      "mcp__github__list_pull_requests",
      "mcp__github__search_pull_requests",
      "mcp__github__get_file_contents",
      "mcp__github__list_commits",
      "mcp__github__get_commit",
      "mcp__github__search_code",
      "mcp__github__list_branches"
    ],
    "deny": [
      "Read(./test-data/**)",
      "Read(**/*.dxf)",
      "Read(**/*.dwg)",
      "Read(**/*.db)",
      "Read(**/*.mdb)",
      "Read(**/*.MDB)",
      "Read(./concrete-agent/packages/core-backend/app/knowledge_base/**/*.json)",
      "Read(./concrete-agent/packages/core-backend/app/knowledge_base/**/*.xml)",
      "Read(./Monolit-Planner/2025_03 OTSKP.xml)",
      "Read(./docs/normy/**/*.pdf)",
      "Read(./URS_MATCHER_SERVICE/backend/data/**/*.csv)"
    ]
  }
}
