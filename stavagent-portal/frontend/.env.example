# StavAgent Portal - Frontend Environment Variables

# =============================================================================
# BACKEND API URL
# =============================================================================
# URL of the stavagent-portal backend API
# Production: https://stavagent-backend.vercel.app
# Development: http://localhost:3001
VITE_API_URL=http://localhost:3001

# =============================================================================
# CORE API URL (concrete-agent)
# =============================================================================
# URL of the concrete-agent CORE API
# Production: https://concrete-agent-1086027517695.europe-west3.run.app
# Development: http://localhost:8000
VITE_CORE_API_URL=https://concrete-agent-1086027517695.europe-west3.run.app

# =============================================================================
# AUTHENTICATION BYPASS (DEVELOPMENT ONLY)
# =============================================================================
# ⚠️ WARNING: NEVER set this to 'true' in production!
# Only use for local development when testing without authentication.
#
# When enabled:
# - All protected routes bypass authentication
# - No JWT token required
# - Login page is skipped
#
# Security: This setting is IGNORED in production builds.
# VITE_DISABLE_AUTH=true  # ← Uncomment ONLY for local development

# =============================================================================
# MONOLIT EXPORT API KEY
# =============================================================================
# Shared secret for calling Monolit's export endpoints from this Portal frontend.
# Must match EXPORT_API_KEY set on the Monolit backend (Render env vars).
# Used by KioskLinksPanel "Import from Monolit" button.
VITE_MONOLIT_EXPORT_API_KEY=
