{
  "name": "@stavagent/portal-frontend",
  "version": "1.0.0",
  "description": "Frontend for StavAgent Portal",
  "type": "module",
  "scripts": {
    "prepare:shared": "node ./scripts/ensure-shared-build.js",
    "predev": "npm run prepare:shared",
    "dev": "vite",
    "prebuild": "npm run prepare:shared",
    "build": "tsc && vite build",
    "postbuild": "node ./scripts/prerender.mjs",
    "build:no-prerender": "SKIP_PRERENDER=1 npm run build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx"
  },
  "dependencies": {
    "@stavagent/portal-shared": "file:../shared",
    "@tanstack/react-query": "^5.17.9",
    "axios": "^1.16.0",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.15.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "puppeteer": "^23.11.1",
    "sirv": "^2.0.4",
    "typescript": "^5.3.3",
    "vite": "^8.0.8"
  }
}
