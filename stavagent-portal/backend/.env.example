# StavAgent Portal - Environment Variables

# Server Configuration
NODE_ENV=development
PORT=3001

# DEV MODE: Set to 'true' to bypass authentication for local testing
# WARNING: Never use in production!
# DISABLE_AUTH=true

# Database
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@host:port/database
# SQLite (development):
DB_PATH=./data/stavagent-portal.db

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=24h

# Email Service (optional - for password reset and email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@stavagent.com

# Service-to-service auth key (kiosk ↔ portal sync)
# Generate: openssl rand -hex 32
# Set the same value on Portal + all kiosks (Monolit, Registry, URS)
# If not set, kiosk endpoints allow unauthenticated access (dev mode)
# SERVICE_API_KEY=

# CORE API Integration
CORE_API_URL=https://concrete-agent-1086027517695.europe-west3.run.app

# CORS Configuration
# Multiple origins are hardcoded in server.js
# Set this to add additional custom origins
# Examples:
#   CORS_ORIGIN=https://www.stavagent.cz
#   CORS_ORIGIN=*  (allow all origins - dev only, not recommended for production)
CORS_ORIGIN=

# File Upload Configuration
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
MAX_FILE_SIZE=10485760
