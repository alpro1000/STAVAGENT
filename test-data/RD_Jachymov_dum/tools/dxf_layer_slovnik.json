    {"match": "čárkovaná",     "element": "_linetype",         "role": "skip",      "conf": 0.6, "note": "line-type layer, not element-semantic"},
    {"match": "kóty",          "element": "_dimension",        "role": "dimension", "conf": 1.0},
    {"match": "návrh šrafa",   "element": "_navrh_hatch",      "role": "hatch_fill","conf": 0.7},
    {"match": "šrafa",         "element": "_hatch",            "role": "hatch_fill","conf": 0.6},
    {"match": "šrafy",         "element": "_hatch",            "role": "hatch_fill","conf": 0.6},
    {"match": "solid fill",    "element": "_solid_fill",       "role": "hatch_fill","conf": 0.6},
    {"match": "rozpiska",      "element": "_titleblock",       "role": "skip",      "conf": 1.0},
    {"match": "popis",         "element": "_annotation",       "role": "skip",      "conf": 1.0},
    {"match": "razítko",       "element": "_annotation",       "role": "skip",      "conf": 1.0},
    {"match": "legenda",       "element": "_annotation",       "role": "skip",      "conf": 1.0},
    {"match": "severka",       "element": "_annotation",       "role": "skip",      "conf": 1.0},
    {"match": "netisk",        "element": "_noplot",           "role": "skip",      "conf": 1.0},
    {"match": "měření",        "element": "_survey",           "role": "skip",      "conf": 1.0},
    {"match": "mereni",        "element": "_survey",           "role": "skip",      "conf": 1.0},
    {"match": "katastr",       "element": "_cadastre",         "role": "skip",      "conf": 1.0},
    {"match": "geometrie",     "element": "_construction_geom","role": "skip",      "conf": 1.0},
    {"match": "draft",         "element": "_draft",            "role": "skip",      "conf": 1.0},
    {"match": "defpoints",     "element": "_defpoints",        "role": "skip",      "conf": 1.0},
    {"match": "textové bloky", "element": "_textblocks",       "role": "skip",      "conf": 1.0},
    {"match": "výškové kóty",  "element": "_level_dim",        "role": "dimension", "conf": 1.0},
    {"match": "bubliny",       "element": "_callout",          "role": "skip",      "conf": 1.0}
  ],
  "block_rules": [
