{
  "_schema": "dxf_layer_slovnik v1",
  "_note": "Accumulative layer-name -> element mapping for DXF-First takeoff (Pattern 49). Match = case-insensitive substring on layer name. Seeded from RD Jáchymov sklad (260217). Grows per project; unknown layers are reported by the parser for accumulation. role: area|length|count|dimension|label|table|hatch_fill|skip.",
  "_seeded_from": "test-data/RD_Jachymov_dum/inputs/vykresy_dxf/260217_sklad/RD Ja_chymov vjezd _ DPZ _ 02.dxf",
  "layer_rules": [
    {"match": "obrysy míst",   "element": "mistnost_podlaha",  "role": "area",      "conf": 1.0, "note": "room outline -> floor area (validated 17.56=17.6, 44.57=44.6)"},
    {"match": "tabulka míst",  "element": "tabulka_mistnosti", "role": "table",     "conf": 1.0},
    {"match": "čísla míst",    "element": "cislo_mistnosti",   "role": "label",     "conf": 1.0},
    {"match": "vnější zdi",    "element": "obvodova_stena",    "role": "length",    "conf": 0.9, "note": "wall footprint -> perimeter; face area = perimeter x height(rez)"},
    {"match": "bourán",        "element": "bourani",           "role": "area",      "conf": 0.9},
    {"match": "dveře",         "element": "dvere",             "role": "count",     "conf": 0.9},
    {"match": "oplocení",      "element": "plot",              "role": "length",    "conf": 0.9},
    {"match": "hydroizolace",  "element": "hydroizolace",      "role": "area",      "conf": 0.85},
    {"match": "ocel heb",      "element": "ocel_sloupek",      "role": "count",     "conf": 0.9},
    {"match": "nosné stěny",   "element": "nosna_stena",       "role": "length",    "conf": 0.9, "note": "dům: load-bearing wall footprint -> obvod"},
    {"match": "obklad",        "element": "obklad",            "role": "area",      "conf": 0.85},
    {"match": "zateplení",     "element": "zatepleni_etics",   "role": "area",      "conf": 0.85},
    {"match": "zařizováky",    "element": "sanita_zarizovak",  "role": "count",     "conf": 0.85, "note": "dům: sanitární zařizovací předměty"},
    {"match": "klempíř",       "element": "klempirina",        "role": "length",    "conf": 0.8},
    {"match": "okna",          "element": "okno",              "role": "count",     "conf": 0.85},
    {"match": "nábytek",       "element": "_nabytek",          "role": "skip",      "conf": 1.0, "note": "návrh furniture — not a takeoff item"},
