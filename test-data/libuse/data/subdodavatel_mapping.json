  "_popis_prefix_special_cases": {
    "_doc": "Item-code prefix in popis triggers override regardless of kapitola. Useful for W##/D##/CW## items where kapitola is HSV-642 (osazení) but real subdodavatel depends on the otvor catalogue.",
    "rules": [
      {"popis_regex": "^(Okno|Window)\\s+W\\d{2}", "subdodavatel": "dodavatel oken"},
      {"popis_regex": "^(Dveře|Door)\\s+D\\d{2}", "subdodavatel": "dodavatel dveří"},
      {"popis_regex": "^(Prosklená příčka|Glass partition)\\s+CW\\d{2}", "subdodavatel": "dodavatel oken (curtain wall)"}
    ]
  },
  "_kapitola_popis_granular": {
    "_doc": "Intra-kapitola granular rules: when kapitola matches AND any keyword pattern is found in popis or skladba_ref.vrstva, override the exact_kapitola_match. Case-insensitive substring search. First matching rule wins (top→bottom order, so put more specific patterns first). Falls through to exact_kapitola_match if no rule matches. Added v1.1 for PSV-783 = Ochrana konstrukcí proti agresivnímu prostředí (multi-trade scope).",
    "PSV-783": [
      {"keywords": ["anti-graffiti", "antigraffiti", "F23"], "subdodavatel": "malíř (anti-graffiti)", "rationale": "F23 anti-graffiti = malíř specialty (penetrace + permanent nátěr)"},
      {"keywords": ["žárové zinkování", "zarove zinkovani", "ČSN EN ISO 1461"], "subdodavatel": "zámečník", "rationale": "Hot-dip galvanizing of ocelové konstrukce = zámečník (LP##/zábradlí/schodiště)"},
      {"keywords": ["prášková", "praskova", "prášková epoxidová barva", "RAL 7016"], "subdodavatel": "zámečník", "rationale": "Powder coating zinkovaných ocelových konstrukcí = follows zámečnické práce"},
      {"keywords": ["pancéřový", "pancerovy", "vsyp pancéř", "F00"], "subdodavatel": "betonář (mazaniny)", "rationale": "F00 pancéřový vsyp = beton technology (rampa, hladcení)"},
      {"keywords": ["epoxid", "F11", "EpoCem"], "subdodavatel": "podlahář (epoxidový/PU)", "rationale": "F11 epoxid sklepy 1.PP = podlahář specialist"},
      {"keywords": ["polyuretan", "F10", "PU systém", "PU 1. vrstva", "PU 2. vrstva", "Posyp křemenného písku do PU"], "subdodavatel": "podlahář (epoxidový/PU)", "rationale": "F10 PU garáž 1.PP = podlahář specialist"},
      {"keywords": ["sikagard", "Sikagard 552W", "Sikagard 555W", "F14", "transparentní bezprašný", "transparentní nátěr"], "subdodavatel": "podlahář (epoxidový/PU)", "rationale": "F14 Sikagard ŽB stěn = Sika/podlahář specialist (552W primer + 555W elastic top coat)"}
    ]
  }
