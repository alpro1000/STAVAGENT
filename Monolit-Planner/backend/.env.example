NODE_ENV=development
PORT=3001
DB_PATH=./data/monolit.db
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports

# CORS Settings
# CORS_ORIGIN is optional - multiple origins are hardcoded in server.js
# Set this to add additional custom origins, or use '*' to allow all origins (dev only)
# Examples:
#   CORS_ORIGIN=https://my-custom-domain.com
#   CORS_ORIGIN=*  (allow all origins - not recommended for production)
CORS_ORIGIN=

# Upload Settings
MAX_FILE_SIZE=10485760

# CORE Integration (Advanced Excel Parser)
# Enable CORE parser as fallback when local parser cannot extract positions
ENABLE_CORE_FALLBACK=true
# CORE API URL (must be running concrete-agent service)
CORE_API_URL=http://localhost:8000
# CORE request timeout in milliseconds (90s to survive Render cold starts)
CORE_TIMEOUT=90000

# Export API Key (required for production)
# Protects POST/GET /api/export-to-registry/:bridge_id from unauthorized access.
# Must match VITE_EXPORT_API_KEY in frontend .env and VITE_MONOLIT_EXPORT_API_KEY in Portal frontend.
# Generate: openssl rand -hex 32
EXPORT_API_KEY=

# LLM API Keys for Formwork AI Assistant
# Chain: Gemini direct → OpenAI direct → CORE Multi-Role → deterministic fallback
# Without these keys, AI falls back to CORE (may be sleeping) → deterministic
# Gemini: fastest (~1s), cheapest (free tier available)
GOOGLE_API_KEY=
# OpenAI: secondary fallback (~2s)
OPENAI_API_KEY=
