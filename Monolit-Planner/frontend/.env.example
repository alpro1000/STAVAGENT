# Example Environment Variables
# Copy this file to .env.development or .env.production and configure

# API URL (backend)
VITE_API_URL=http://localhost:3001

# DEV MODE: Disable authentication for quick testing
# Set to 'true' to bypass login (FOR DEVELOPMENT ONLY!)
# ⚠️ NEVER enable this in production!
VITE_DISABLE_AUTH=false

# Concrete Agent CORE Engine URL (optional)
VITE_CORE_API_URL=https://concrete-agent-3uxelthc4q-ey.a.run.app

# Registry TOV URL (for formwork rental calculator link)
VITE_REGISTRY_URL=https://stavagent-backend-ktwx.vercel.app

# Export API Key — must match EXPORT_API_KEY on the backend
# Required to call POST/GET /api/export-to-registry/:bridge_id
VITE_EXPORT_API_KEY=
