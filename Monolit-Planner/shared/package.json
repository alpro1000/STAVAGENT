{
  "name": "@stavagent/monolit-shared",
  "version": "1.0.0",
  "description": "Shared types and formulas for Monolit Calculator",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./src/calculators/batchCalculator": {
      "types": "./src/calculators/batchCalculator.ts",
      "import": "./src/calculators/batchCalculator.ts",
      "default": "./src/calculators/batchCalculator.ts"
    },
    "./src/*": {
      "types": "./*.ts",
      "import": "./*.ts",
      "default": "./*.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "vitest": "^4.0.16"
  }
}
