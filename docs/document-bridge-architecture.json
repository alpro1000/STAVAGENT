  "architectural_decision": {
    "title": "MCP scenario ≠ SaaS scenario",
    "comparison": [
      {
        "aspect": "Who extracts parameters",
        "mcp": "User's LLM (ChatGPT/Claude)",
        "saas": "STAVAGENT backend"
      },
      {
        "aspect": "Infrastructure",
        "mcp": "MCP server + engine",
        "saas": "MCP server + engine + MinerU + regex + LLM fallback"
      },
      {
        "aspect": "Operating cost",
        "mcp": "Low (no LLM in our stack)",
        "saas": "Higher (Bedrock/Gemini calls)"
      },
      {
        "aspect": "Target user",
        "mcp": "AI-literate developer/rozpočtář",
        "saas": "Mainstream rozpočtář without AI"
      },
      {
        "aspect": "Dependency",
        "mcp": "User needs ChatGPT/Claude subscription",
        "saas": "Only STAVAGENT account"
      },
      {
        "aspect": "Status",
        "mcp": "ACTIVE (v1.0)",
        "saas": "BACKLOG (TASK_SmartInput_DocumentBridge)"
      }
    ],
    "why_both": [
      "MCP is cheap and fast for early adopters",
      "SaaS Document Bridge is necessary for mainstream — rozpočtář without AI has nowhere to run LLM. Backend must do extraction itself."
    ],
    "common_foundation": "Both scenarios rely on golden tests as source of truth. Each added TZ in test-data/tz/ makes both systems smarter."
  }
}
